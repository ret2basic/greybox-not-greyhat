{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ret2basic/greybox-not-greyhat/schemas/inferforge-config.schema.json",
  "title": "InferForge v2 configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 2
    },
    "exclude": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "directories": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "globs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "include_extensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^\\.?[A-Za-z0-9]+$"
      },
      "uniqueItems": true
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_file_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "max_files": {
          "type": "integer",
          "minimum": 1
        },
        "max_total_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "disabled": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^IF[WC][0-9]{3}$"
          },
          "uniqueItems": true
        },
        "severity_overrides": {
          "type": "object",
          "additionalProperties": {
            "enum": [
              "info",
              "low",
              "medium",
              "high",
              "critical"
            ]
          }
        }
      }
    },
    "trust_boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "pattern"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "pattern": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
