API_URL=http://localhost:4042
NEXT_PUBLIC_API_URL=http://localhost:6004
APP_ENVIRONMENT=local

# Get your project ID from https://dashboard.reown.com
NEXT_PUBLIC_PROJECT_ID=YOUR_PROJECT_ID_HERE

# Server-side Solana RPC upstreams. Never expose paid RPC URLs as NEXT_PUBLIC_*.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
# Optional explicit WS upstreams. If omitted, ws(s) URLs are derived from the HTTP RPC URLs.
SOLANA_WS_RPC_URL=
SOLANA_DEVNET_WS_RPC_URL=
SOLANA_RPC_PROXY_ALLOWED_ORIGINS=http://localhost:3000

# M0 Orchestration API key (server-side only)
M0_ORCHESTRATION_API_KEY=YOUR_M0_ORCHESTRATION_API_KEY_HERE

# Public wallet address used for quote previews
NEXT_PUBLIC_M0_QUOTE_PREVIEW_WALLET=YOUR_PREVIEW_WALLET_ADDRESS_HERE

# Public wallet used for vault quote simulation fallback
NEXT_PUBLIC_GLOW_QUOTE_SIMULATION_OWNER=YOUR_SIMULATION_WALLET_ADDRESS_HERE

# Public Glow vault address used by the app
NEXT_PUBLIC_GLOW_VAULT_ADDRESS=EzDmLUHTj53mSLN4BBrsuW8w3Gvc1iDGiYCXrkwm4vrR
